+        let offset = 0;
+        for (let y = 0; y < 64; y++) {
+            for (let x = 0; x < 64; x++) {
+                pixels[offset++] = (x * 17 + y * 13) % 256;
+                pixels[offset++] = (x * 7 + y * 29) % 256;
+                pixels[offset++] = (x * 31 + y * 3) % 256;
+                pixels[offset++] = 255;
+            }
+        }
+        const img = CanvasKit.MakeImage({
+            'width': 64,
+            'height': 64,
+            'alphaType': CanvasKit.AlphaType.Unpremul,
+            'colorType': CanvasKit.ColorType.RGBA_8888,
+            'colorSpace': CanvasKit.ColorSpace.SRGB,
+        }, pixels, 64 * 4);
+
+        const bytesEqual = (a, b) => {
+            expect(Array.from(a)).toEqual(Array.from(b));
+        };
+        const pngZlibLevelHint = (bytes) => {
+            let chunk = 8;
+            while (chunk + 12 <= bytes.length) {
+                const size = (bytes[chunk] << 24) | (bytes[chunk + 1] << 16) |
+                             (bytes[chunk + 2] << 8) | bytes[chunk + 3];
+                const type = String.fromCharCode(...bytes.subarray(chunk + 4, chunk + 8));
+                if (type === 'IDAT') {
+                    const cmf = bytes[chunk + 8];
+                    const flags = bytes[chunk + 9];
+                    expect(cmf & 0x0f).toEqual(8);
+                    expect(((cmf << 8) | flags) % 31).toEqual(0);
+                    return flags >> 6;
+                }
+                chunk += 12 + size;
+            }
+            throw new Error('PNG has no IDAT chunk');
+        };
+        const webpPayload = (bytes) => {
+            let chunk = 12;
+            while (chunk + 8 <= bytes.length) {
+                const type = String.fromCharCode(...bytes.subarray(chunk, chunk + 4));
+                const size = bytes[chunk + 4] | (bytes[chunk + 5] << 8) |
+                             (bytes[chunk + 6] << 16) | (bytes[chunk + 7] << 24);
+                if (type === 'VP8 ' || type === 'VP8L') {
+                    return type;
+                }
+                chunk += 8 + size + (size & 1);
+            }
+            throw new Error('WebP has no VP8 or VP8L payload');
+        };
